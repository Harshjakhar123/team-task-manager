# --- Backend environment variables ---

# PostgreSQL connection string. On Railway this is provided automatically when
# you attach a Postgres plugin (reference it as ${{Postgres.DATABASE_URL}}).
# Leave unset locally to fall back to a zero-config SQLite file.
DATABASE_URL=postgresql://user:password@localhost:5432/taskmanager

# Secret used to sign JWTs. MUST be a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Access token lifetime in minutes (default 1440 = 24h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated CORS origins. Only needed if the frontend is deployed
# separately from the API; the default single-service deploy needs no value.
CORS_ORIGINS=http://localhost:5173

ENV=development
